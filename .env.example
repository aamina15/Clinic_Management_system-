# =============================================================================
# Smart Clinic Management System — Root Environment Variables
# Copy to .env and fill in values for local Docker Compose development.
# =============================================================================

# PostgreSQL (local Docker)
POSTGRES_DB=clinic_management
POSTGRES_USER=clinic_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_PORT=5432

# Backend (Spring Boot)
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=change_me_use_a_long_random_secret_at_least_256_bits
JWT_EXPIRATION_MS=86400000

# Frontend (Next.js)
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
