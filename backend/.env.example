# Backend Environment Variables
# Copy to .env or configure in Railway.
# Spring Boot reads these when exported to the shell or via platform env injection.

SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/clinic_management
SPRING_DATASOURCE_USERNAME=clinic_user
SPRING_DATASOURCE_PASSWORD=change_me_secure_password
JWT_SECRET=change_me_use_a_long_random_secret_at_least_256_bits
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:3000
SERVER_PORT=8080
